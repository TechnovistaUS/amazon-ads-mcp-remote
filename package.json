{
  "name": "amazon-ads-mcp-remote-server",
  "version": "1.0.0",
  "description": "Remote MCP Server for Amazon Ads API with OAuth 2.0 and automatic token refresh. Connect directly to Claude via HTTPS.",
  "type": "module",
  "main": "dist/index-v2-extended.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index-v2-extended.js",
    "dev": "npm run build && npm run start",
    "inspect": "npx @modelcontextprotocol/inspector npm run start"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "qs": "^6.15.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
