# Amazon Ads OAuth Configuration
AMAZON_CLIENT_ID=amzn1.application-oa2-client.eb73a2fb8db24cbda9568305c23fcd6e
AMAZON_CLIENT_SECRET=amzn1.oa2-cs.v1.29b8a39598dd4621649841415efb061970bf21a77431855376a8e82e200d4cc3

# Initial Refresh Token (obtain from first OAuth flow)
# After the first authorization, this will be automatically updated
AMAZON_REFRESH_TOKEN=

# Amazon Ads API Configuration
AMAZON_API_REGION=NA

# Server Configuration
PORT=443
HTTPS_PORT=443
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Token Refresh Configuration (in minutes)
TOKEN_REFRESH_INTERVAL=55

# ngrok/Tunnel Configuration (for development)
NGROK_AUTHTOKEN=
PUBLIC_URL=https://your-domain.com

# HTTPS Certificate Configuration (for production)
# If using self-signed certificates:
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# MCP Server Configuration
MCP_SERVER_NAME=amazon-ads-mcp-remote
MCP_SERVER_VERSION=1.0.0
